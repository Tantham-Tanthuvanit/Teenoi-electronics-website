---
// src/components/contact-box.astro
import "../styles/colors.css";
---

<div class="contact-section">
    <h1 class="title">Contact</h1>
    
    <div class="contact-box">
        <div class="contact-item">
            <i class="fa-solid fa-phone"></i>
            <span>000-000-0000</span>
        </div>
        
        <div class="contact-item">
            <i class="fa-solid fa-envelope"></i>
            <span>000-000-0000</span>
        </div>
        
        <div class="contact-item">
            <i class="fa-brands fa-instagram"></i>
            <a href="https://www.instagram.com/teenoi_electronics/" target="_blank">teenoi_electronics</a>
        </div>
    </div>
</div>

<style>
    .contact-section {
        display: flex;
        flex-direction: column;
        width: 40%; /* Matches your other pages */
    }

    .title {
        color: var(--color-accent);
        font-size: 3rem;
        margin-bottom: 20px;
    }

    /* The inner box */
    .contact-box {
        background-color: var(--color-tertiary);
        border: 0.2rem solid var(--color-secondary);
        border-radius: 1rem;
        padding: 40px;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 30px; 
        box-sizing: border-box;
    }

    /* Each individual row (Icon + Text) */
    .contact-item {
        display: flex;
        align-items: center;
        gap: 20px; 
        color: var(--color-accent);
        font-size: 1.2rem;
        font-weight: bold;
    }

    /* Sizing the icons */
    .contact-item i {
        font-size: 1.8rem;
        width: 30px; 
        text-align: center;
    }

    /* Fixing the Link Color */
    .contact-item a {
        color: var(--color-accent); 
        text-decoration: none; 
    }

    .contact-item a:hover {
        text-decoration: underline; 
    }

    /* Mobile responsiveness */
    @media (max-width: 1200px) {
        .contact-section {
            width: 80%;
        }
    }
</style>